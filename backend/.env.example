# =============================================================
# IDEA PORTAL — Environment Variables Template
# Copy this file to .env and fill in your real values
# =============================================================

# Flask
SECRET_KEY=change-me-to-a-random-secret-key

# Redis (default local install)
REDIS_URL=redis://localhost:6379/0

# ---- Email (SMTP) ----
# For Gmail: use App Password (Settings > Security > 2FA > App Passwords)
# For Outlook/Office365: use SMTP relay
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Portal name shown in email subjects
PORTAL_NAME=CCEW Research & Innovation Portal
