# CCEW Idea Portal — Environment Configuration
# Generated for development - Change in production

# Flask
SECRET_KEY=ccew-dev-secret-key-change-in-production

# Redis (for Celery tasks - can use local or remote)
REDIS_URL=redis://localhost:6379/0

# Email (SMTP) - Optional, set if using email features
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@ccew-portal.com

# Portal Meta
PORTAL_NAME=CCEW Research & Innovation Portal
PORTAL_URL=http://localhost:8000
